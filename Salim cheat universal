-- =====================
-- DRAG MENU
-- =====================
local dragging = false
local dragStart = nil
local startTitlePos = nil
local startFramePos = nil
local hasDragged = false
local DRAG_THRESHOLD = 10

titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        hasDragged = false
        dragStart = input.Position
        startTitlePos = titleBar.AbsolutePosition
        startFramePos = frame.AbsolutePosition
    end
end)

titleBar.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
        if not hasDragged then
            frame.Visible = not frame.Visible
            titleBar.Text = frame.Visible and "▼ Salim Cheat 2.67" or "▲ Salim Cheat 2.67"
        end
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart

        if delta.Magnitude >= DRAG_THRESHOLD then
            hasDragged = true
        end

        if hasDragged then
            titleBar.Position = UDim2.new(0, startTitlePos.X + delta.X, 0, startTitlePos.Y + delta.Y)
            frame.Position = UDim2.new(0, startFramePos.X + delta.X, 0, startFramePos.Y + delta.Y)
        end
    end
end)

-- =====================
-- DRAG FOV
-- =====================
local fovDragging = false

UserInputService.InputBegan:Connect(function(input)
    if not fovLocked and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1) then
        local touchPos = input.Position
        local titleAbsPos = titleBar.AbsolutePosition
        local titleAbsSize = titleBar.AbsoluteSize
        local frameAbsPos = frame.AbsolutePosition
        local frameAbsSize = frame.AbsoluteSize

        local onTitle = touchPos.X >= titleAbsPos.X and touchPos.X <= titleAbsPos.X + titleAbsSize.X
            and touchPos.Y >= titleAbsPos.Y and touchPos.Y <= titleAbsPos.Y + titleAbsSize.Y

        local onFrame = frame.Visible and touchPos.X >= frameAbsPos.X and touchPos.X <= frameAbsPos.X + frameAbsSize.X
            and touchPos.Y >= frameAbsPos.Y and touchPos.Y <= frameAbsPos.Y + frameAbsSize.Y

        if not onTitle and not onFrame then
            fovDragging = true
            customFovX = touchPos.X
            customFovY = touchPos.Y
            circle.Position = UDim2.new(0, customFovX, 0, customFovY)
            centerDot.Position = UDim2.new(0, customFovX, 0, customFovY)
        end
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if fovDragging and not fovLocked and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement) then
        customFovX = input.Position.X
        customFovY = input.Position.Y
        circle.Position = UDim2.new(0, customFovX, 0, customFovY)
        centerDot.Position = UDim2.new(0, customFovX, 0, customFovY)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if fovDragging and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1) then
        fovDragging = false
    end
end)

