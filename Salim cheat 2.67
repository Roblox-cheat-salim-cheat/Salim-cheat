-- =====================
-- SYSTÈME DE DRAG (MENU DÉPLAÇABLE)
-- =====================
local dragging = false
local dragStart = nil
local startPos = nil
local hasDragged = false

titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        hasDragged = false
        dragStart = input.Position
        startPos = titleBar.Position
    end
end)

titleBar.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        if delta.Magnitude > 5 then
            hasDragged = true
        end
        local newPos = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
        titleBar.Position = newPos
        frame.Position = UDim2.new(
            newPos.X.Scale,
            newPos.X.Offset,
            newPos.Y.Scale,
            newPos.Y.Offset + 30
        )
    end
end)

-- Afficher/masquer le menu (clic sans drag)
titleBar.MouseButton1Click:Connect(function()
    if not hasDragged then
        frame.Visible = not frame.Visible
    end
end)

-- =====================
-- FONCTIONS ESP
-- =====================
local function createESP(player)
    if player == LocalPlayer then return end

    local highlight = Instance.new("Highlight")
    highlight.FillColor = Color3.fromRGB(255, 0, 0)
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop

    local nameTag = Instance.new("BillboardGui")
    nameTag.Size = UDim2.new(0, 100, 0, 40)
    nameTag.StudsOffset = Vector3.new(0, 3, 0)
    nameTag.AlwaysOnTop = true

    local nameLabel = Instance.new("TextLabel", nameTag)
    nameLabel.Size = UDim2.new(1, 0, 0.5, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    nameLabel.TextStrokeTransparency = 0.5
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 14
    nameLabel.Text = player.Name

    local healthLabel = Instance.new("TextLabel", nameTag)
    healthLabel.Size = UDim2.new(1, 0, 0.5, 0)
    healthLabel.Position = UDim2.new(0, 0, 0.5, 0)
    healthLabel.BackgroundTransparency = 1
    healthLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
    healthLabel.TextStrokeTransparency = 0.5
    healthLabel.Font = Enum.Font.Gotham
    healthLabel.TextSize = 12

    espObjects[player] = {
        highlight = highlight,
        nameTag = nameTag,
        healthLabel = healthLabel
    }

    local function updateESP()
        if player.Character and espEnabled then
            highlight.Parent = player.Character
            nameTag.Parent = player.Character:FindFirstChild("Head")

            local humanoid = player.Character:FindFirstChild("Humanoid")
            if humanoid then
                local health = math.floor(humanoid.Health)
                local maxHealth = humanoid.MaxHealth
                healthLabel.Text = health .. "/" .. maxHealth

                local ratio = health / maxHealth
                healthLabel.TextColor3 = Color3.fromRGB(255 * (1 - ratio), 255 * ratio, 0)
            end
        else
            highlight.Parent = nil
            nameTag.Parent = nil
        end
    end

    player.CharacterAdded:Connect(function()
        wait(0.5)
        updateESP()
    end)

    updateESP()
end

local function removeESP(player)
    if espObjects[player] then
        espObjects[player].highlight:Destroy()
        espObjects[player].nameTag:Destroy()
        espObjects[player] = nil
    end
end

-- =====================
-- FONCTIONS TRACERS
-- =====================
local function createTracer(player)
    if player == LocalPlayer then return end

    local line = Drawing.new("Line")
    line.Visible = false
    line.Color = Color3.fromRGB(255, 0, 0)
    line.Thickness = 1
    line.Transparency = 1

    tracerLines[player] = line
end

local function removeTracer(player)
    if tracerLines[player] then
        tracerLines[player]:Remove()
        tracerLines[player] = nil
    end
end

-- Initialiser pour les joueurs existants
for _, player in pairs(Players:GetPlayers()) do
    createESP(player)
    createTracer(player)
end

Players.PlayerAdded:Connect(function(player)
    createESP(player)
    createTracer(player)
end)

Players.PlayerRemoving:Connect(function(player)
    removeESP(player)
    removeTracer(player)
end)

-- =====================
-- ÉVÉNEMENTS BOUTONS
-- =====================
aimButton.MouseButton1Click:Connect(function()
    aimAssist = not aimAssist
    aimButton.Text = "Aim Assist : " .. (aimAssist and "ON" or "OFF")
    aimButton.BackgroundColor3 = aimAssist and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(60, 60, 60)
end)

fovButton.MouseButton1Click:Connect(function()
    showFOV = not showFOV
    fovButton.Text = "FOV Visible : " .. (showFOV and "ON" or "OFF")
    circle.Visible = showFOV
    centerDot.Visible = showFOV
    fovButton.BackgroundColor3 = showFOV and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(60, 60, 60)
end)

espButton.MouseButton1Click:Connect(function()
    espEnabled = not espEnabled
    espButton.Text = "ESP : " .. (espEnabled and "ON" or "OFF")
    espButton.BackgroundColor3 = espEnabled and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(60, 60, 60)

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and espObjects[player] then
            if espEnabled and player.Character then
                espObjects[player].highlight.Parent = player.Character
                espObjects[player].nameTag.Parent = player.Character:FindFirstChild("Head")
            else
                espObjects[player].highlight.Parent = nil
                espObjects[player].nameTag.Parent = nil
            end
        end
    end
end)

tracerButton.MouseButton1Click:Connect(function()
    tracersEnabled = not tracersEnabled
    tracerButton.Text = "Tracers : " .. (tracersEnabled and "ON" or "OFF")
    tracerButton.BackgroundColor3 = tracersEnabled and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(60, 60, 60)

    if not tracersEnabled then
        for _, line in pairs(tracerLines) do
            line.Visible = false
        end
    end
end)

fovBox.FocusLost:Connect(function()
    local num = tonumber(fovBox.Text)
    if num and num > 0 and num <= 500 then
        FOV = num
        circle.Size = UDim2.new(0, FOV * 2, 0, FOV * 2)
        fovBox.PlaceholderText = "FOV : " .. FOV
    end
    fovBox.Text = ""
end)

-- =====================
-- OBTENIR LE JOUEUR LE PLUS PROCHE
-- =====================
local function getClosestPlayer()
    local closest = nil
    local shortestDist = FOV
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local head = player.Character:FindFirstChild("Head")
            local humanoid = player.Character:FindFirstChild("Humanoid")

            if head and humanoid and humanoid.Health > 0 then
                local pos, visible = Camera:WorldToViewportPoint(head.Position)

                if visible then
                    local screenPos = Vector2.new(pos.X, pos.Y)
                    local dist = (screenPos - screenCenter).Magnitude

                    if dist < shortestDist then
                        shortestDist = dist
                        closest = player
                    end
                end
            end
        end
    end

    return closest, shortestDist
end

-- =====================
-- BOUCLE PRINCIPALE
-- =====================
RunService.RenderStepped:Connect(function()
    -- METTRE À JOUR LA POSITION DU FOV AU VRAI CENTRE DE L'ÉCRAN
    local viewportSize = Camera.ViewportSize
    local centerX = viewportSize.X / 2
    local centerY = viewportSize.Y / 2

    circle.Position = UDim2.new(0, centerX, 0, centerY)
    centerDot.Position = UDim2.new(0, centerX, 0, centerY)

    -- Aim Assist
    if aimAssist then
        local target, dist = getClosestPlayer()

        if target and target.Character then
            local head = target.Character:FindFirstChild("Head")

            if head then
                local targetPos = head.Position
                local currentPos = Camera.CFrame.Position
                local newCFrame = CFrame.new(currentPos, targetPos)
                Camera.CFrame = Camera.CFrame:Lerp(newCFrame, aimStrength)
            end
        end
    end

    -- Mise à jour des traceurs
    if tracersEnabled then
        local screenBottom = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)

        for player, line in pairs(tracerLines) do
            if player.Character then
                local root = player.Character:FindFirstChild("HumanoidRootPart")
                local humanoid = player.Character:FindFirstChild("Humanoid")

                if root and humanoid and humanoid.Health > 0 then
                    local pos, visible = Camera:WorldToViewportPoint(root.Position)

                    if visible then
                        line.From = screenBottom
                        line.To = Vector2.new(pos.X, pos.Y)
                        line.Visible = true
                    else
                        line.Visible = false
                    end
                else
                    line.Visible = false
                end
            else
                line.Visible = false
            end
        end
    end

    -- Mise à jour santé ESP
    if espEnabled then
        for player, esp in pairs(espObjects) do
            if player.Character then
                local humanoid = player.Character:FindFirstChild("Humanoid")
                if humanoid then
                    local health = math.floor(humanoid.Health)
                    local maxHealth = humanoid.MaxHealth
                    esp.healthLabel.Text = health .. "/" .. maxHealth

                    local ratio = health / maxHealth
                    esp.healthLabel.TextColor3 = Color3.fromRGB(255 * (1 - ratio), 255 * ratio, 0)
                end
            end
        end
    end
end)
