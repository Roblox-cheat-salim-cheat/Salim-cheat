RunService.RenderStepped:Connect(function()
	frameCounter = frameCounter + 1

	-- FOV circle position (léger, chaque frame OK)
	if not customFovX or not customFovY then
		local cx, cy = getGameCenter()
		circle.Position = UDim2.new(0, cx, 0, cy)
		centerDot.Position = UDim2.new(0, cx, 0, cy)
	end

	-- Seulement si aim assist OU silent aim est actif
	if aimAssist or silentAim then
		local target = getClosestPlayer()
		silentAimTarget = target

		-- Aim Assist
		if aimAssist and target and target.Character then
			local head = target.Character:FindFirstChild("Head")
			if head then
				local targetPos = head.Position
				local currentPos = Camera.CFrame.Position
				local newCFrame = CFrame.new(currentPos, targetPos)
				Camera.CFrame = Camera.CFrame:Lerp(newCFrame, aimStrength)
			end
		end

		-- Update status label
		if silentAim and silentAimTarget then
			silentStatusLabel.Text = "🎯 Cible: " .. silentAimTarget.Name
			silentStatusLabel.TextColor3 = Color3.fromRGB(170, 0, 255)
		elseif silentAim then
			silentStatusLabel.Text = "Silent: aucune cible"
			silentStatusLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
		end
	else
		silentAimTarget = nil
	end

	-- Tracers (toutes les 2 frames pour économiser)
	if tracersEnabled and frameCounter % 2 == 0 then
		local screenBottom = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)

		for player, line in pairs(tracerLines) do
			local ok = pcall(function()
				if player.Character then
					local root = player.Character:FindFirstChild("HumanoidRootPart")
					local humanoid = player.Character:FindFirstChild("Humanoid")

					if root and humanoid and humanoid.Health > 0 then
						local pos, visible = Camera:WorldToViewportPoint(root.Position)
						if visible then
							line.From = screenBottom
							line.To = Vector2.new(pos.X, pos.Y)
							line.Visible = true
						else
							line.Visible = false
						end
					else
						line.Visible = false
					end
				else
					line.Visible = false
				end
			end)

			if not ok then
				line.Visible = false
			end
		end
	end

	-- ESP health update (toutes les 5 frames)
	if espEnabled and frameCounter % 5 == 0 then
		for player, esp in pairs(espObjects) do
			pcall(function()
				if player.Character then
					local humanoid = player.Character:FindFirstChild("Humanoid")
					if humanoid then
						local health = math.floor(humanoid.Health)
						local maxHealth = humanoid.MaxHealth
						esp.healthLabel.Text = health .. "/" .. maxHealth
						local ratio = health / maxHealth
						esp.healthLabel.TextColor3 = Color3.fromRGB(255 * (1 - ratio), 255 * ratio, 0)
					end
				end
			end)
		end
	end

	-- Reset counter pour éviter overflow
	if frameCounter >= 1000 then
		frameCounter = 0
	end
end)
