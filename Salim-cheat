local dragging = false
local dragOffset = Vector2.new(0, 0)
local hasDragged = false
local DRAG_THRESHOLD = 5

local fovDragging = false

-- =====================
-- FONCTION UTILITAIRE
-- =====================
local function isPointInGui(point, guiObject)
	local pos = guiObject.AbsolutePosition
	local size = guiObject.AbsoluteSize
	return point.X >= pos.X and point.X <= pos.X + size.X
		and point.Y >= pos.Y and point.Y <= pos.Y + size.Y
end

-- =====================
-- DRAG MENU - InputBegan sur titleBar
-- =====================
titleBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		hasDragged = false
		local mousePos = input.Position
		local containerPos = container.AbsolutePosition
		dragOffset = Vector2.new(mousePos.X - containerPos.X, mousePos.Y - containerPos.Y)
	end
end)

-- =====================
-- UN SEUL InputChanged GLOBAL (pas de conflit)
-- =====================
UserInputService.InputChanged:Connect(function(input)
	local isMove = input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch

	if not isMove then return end

	-- DRAG MENU
	if dragging then
		local mousePos = input.Position
		local newX = mousePos.X - dragOffset.X
		local newY = mousePos.Y - dragOffset.Y

		if not hasDragged then
			local currentPos = container.AbsolutePosition
			local delta = Vector2.new(newX - currentPos.X, newY - currentPos.Y)
			if delta.Magnitude >= DRAG_THRESHOLD then
				hasDragged = true
				titleBar.BackgroundTransparency = 0.1
			end
		end

		if hasDragged then
			local viewportSize = Camera.ViewportSize
			newX = math.clamp(newX, 0, viewportSize.X - container.AbsoluteSize.X)
			newY = math.clamp(newY, 0, viewportSize.Y - 30)
			container.Position = UDim2.new(0, newX, 0, newY)
		end
		return
	end

	-- DRAG FOV
	if fovDragging and not fovLocked then
		customFovX = input.Position.X
		customFovY = input.Position.Y
		circle.Position = UDim2.new(0, customFovX, 0, customFovY)
		centerDot.Position = UDim2.new(0, customFovX, 0, customFovY)
	end
end)

-- =====================
-- UN SEUL InputBegan GLOBAL
-- =====================
UserInputService.InputBegan:Connect(function(input)
	if input.UserInputType ~= Enum.UserInputType.Touch and input.UserInputType ~= Enum.UserInputType.MouseButton1 then
		return
	end

	-- FOV DRAG
	if not fovLocked and not dragging then
		local touchPos = input.Position
		if not isPointInGui(touchPos, container) then
			fovDragging = true
			customFovX = touchPos.X
			customFovY = touchPos.Y
			circle.Position = UDim2.new(0, customFovX, 0, customFovY)
			centerDot.Position = UDim2.new(0, customFovX, 0, customFovY)
		end
	end
end)

